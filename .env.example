APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ourrag
POSTGRES_USER=ourrag
POSTGRES_PASSWORD=secret

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=document_chunks
QDRANT_TIMEOUT=10

OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=bielik
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_KEEP_ALIVE=5m
OLLAMA_MAX_CONCURRENCY=2

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_TIMEOUT_SECONDS=30

FILES_STORAGE_DRIVER=local
FILES_STORAGE_ROOT=/app/data/storage
DATA_ROOT=/app/data

QUEUE_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379
WORKER_CONCURRENCY=2

RAG_TOP_K=5
RAG_MAX_CONTEXT_CHUNKS=5
RAG_MIN_SCORE_THRESHOLD=

RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_CHUNKING_STRATEGY=markdown_semantic_v1

CHAT_RECENT_MESSAGES_LIMIT=8
CHAT_SUMMARY_ENABLED=true
CHAT_SUMMARY_REFRESH_EVERY_N_MESSAGES=8

FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
VITE_APP_ENV=local
VITE_APP_DEBUG=true
VITE_API_BASE_URL=http://localhost:8000
